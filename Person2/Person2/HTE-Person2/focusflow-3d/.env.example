# LLM 後端（擇一即可）

# Minimax（推薦）
#MINIMAX_API_KEY=
#MINIMAX_MODEL_ID=MiniMax-M2.5
#MINIMAX_CHAT_MODEL_ID=MiniMax-M2.5

# OpenAI
# OPENAI_API_KEY=
# OPENAI_MODEL_ID=gpt-4o-mini
# OPENAI_CHAT_MODEL_ID=gpt-4o

# Anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL_ID=claude-3-5-haiku-20241022
# ANTHROPIC_CHAT_MODEL_ID=claude-3-5-sonnet-20241022

# Ollama 本機（需設 LLM_PROVIDER=ollama）
# LLM_PROVIDER=ollama
# OLLAMA_MODEL_ID=llama3.2
# OLLAMA_CHAT_MODEL_ID=llama3.2

# PDF 上傳：Vercel Blob（優先）或 S3 或僅記憶體
# BLOB_READ_WRITE_TOKEN=   # Vercel Blob（於 Vercel Storage 建立後取得）
# NEXT_PUBLIC_S3_BUCKET=

# Supabase Auth (client-side)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase（PRD 持久化：Storage + PostgreSQL）
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=uploads
# SUPABASE_CACHE_TABLE=api_cache
# SUPABASE_INGEST_TABLE=ingested_knowledge_graphs
# SUPABASE_RESOURCE_CACHE_TABLE=resource_cache

# Vector storage / embeddings (RAG pipeline)
# SUPABASE_MATERIAL_TABLE=materials
# SUPABASE_MATERIAL_CHUNK_TABLE=material_chunks
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Demo：設為 1 時 ingest/quiz/explain/session-summary 優先回傳 public/demo-cache/*.json
# DEMO_FALLBACK=1
